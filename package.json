{
  "name": "@agentio/core",
  "version": "0.1.0",
  "description": "Slim harness between your UI and any agent CLI — message queue, tools, and events via SQLite + agentio CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentio": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "example": "npm run build && npm install --prefix examples/runner-control && npm run start --prefix examples/runner-control"
  },
  "keywords": [
    "agent",
    "harness",
    "cli",
    "codex",
    "claude",
    "sqlite",
    "orchestration",
    "agentic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentio-hq/agentio.git"
  },
  "bugs": {
    "url": "https://github.com/agentio-hq/agentio/issues"
  },
  "homepage": "https://github.com/agentio-hq/agentio#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
